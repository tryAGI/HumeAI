<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <NoWarn>$(NoWarn);CS3002;CS3003;CS1591</NoWarn>
  </PropertyGroup>

  <PropertyGroup Label="Nuget">
    <Description>C# SDK for the Hume AI API -- emotion recognition, expression measurement, empathic voice interface (EVI), and text-to-speech (TTS).</Description>
    <PackageTags>hume;hume-ai;emotion-ai;emotion-recognition;expression-measurement;tts;text-to-speech;evi;empathic-voice;api;client;sdk;dotnet;openapi;autosdk</PackageTags>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.Extensions.AI.Abstractions" Version="10.4.1" />
  </ItemGroup>

</Project>
